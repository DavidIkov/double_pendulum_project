<?xml version="1.0"?>
<robot name="double_pendulum">
    <link name="platform">
        <visual>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </visual>
        <inertial>
            <mass value="0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>
    <link name="rotating_stick">
        <visual>
            <origin xyz="2 0 0.25" rpy="0 0 0"/>
            <geometry>
                <box size="4 0.5 0.5"/>
            </geometry>
        </visual>
        <inertial>
            <origin xyz="2 0 0.25" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
        <collision>
            <origin xyz="2 0 0.25" rpy="0 0 0"/>
            <geometry>
                <box size="4 0.5 0.5"/>
            </geometry>
        </collision>

    </link>
    <joint name="platform_to_stick" type="continuous">
        <parent link="platform"/>
        <child link="rotating_stick"/>
        <origin xyz="0 0 0.5" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>
    <link name="pendulum0">
        <visual>
            <origin xyz="0 1 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 2 0.2"/>
            </geometry>
        </visual>
        <inertial>
            <origin xyz="0 1 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
        <collision>
            <origin xyz="0 1 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 2 0.2"/>
            </geometry>
        </collision>

    </link>
    <joint name="stick_to_pendulum0" type="continuous">
        <parent link="rotating_stick"/>
        <child link="pendulum0"/>
        <origin xyz="4.1 0 0.25" rpy="0 0 0"/> 
        <axis xyz="1 0 0"/>
    </joint>
    <link name="pendulum1">
        <visual>
            <origin xyz="0 1 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 2 0.2"/>
            </geometry>
        </visual>
        <inertial>
            <origin xyz="0 1 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
        <collision>
            <origin xyz="0 1 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 2 0.2"/>
            </geometry>
        </collision>
    </link>
    <joint name="pendulum0_to_pendulum1" type="continuous">
        <parent link="pendulum0"/>
        <child link="pendulum1"/>
        <origin xyz="0 2 0" rpy="0 0 0"/> 
        <axis xyz="1 0 0"/>
    </joint>

</robot>
